// secrets.h.example — OPTIONAL developer fast-path.
//
// You do NOT need this file. Without it, the firmware brings up a SoftAP
// captive portal ("SMSGGDJ-setup") on first boot so you pick WiFi from a phone
// or laptop browser — the same flow a shipped binary uses.
//
// Copy it to secrets.h only if you'd rather hard-code your dev network and skip
// the portal during development:
//
//   cp secrets.h.example secrets.h
//
// secrets.h is git-ignored so creds never enter history, and release builds
// (idf.py -DSHIP=1) ignore it entirely — they always use the portal.
#pragma once

#define WIFI_SSID  "your-network"
#define WIFI_PASS  "your-password"

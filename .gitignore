# ESP-IDF build output
/build/
/dist/
*.bin
*.elf
*.map
*.hex

# Exception: the published release image IS committed so GitHub Pages can serve
# it to the web flasher (see tools/make-release.sh, docs/firmware/).
!docs/firmware/
!docs/firmware/*.bin

# ESP-IDF generated config + fetched managed components (deps pinned in
# dependencies.lock, which IS committed for reproducibility).
/sdkconfig
/sdkconfig.old
/managed_components/

# Secrets (WiFi creds, etc.) — keep out of history
secrets.h
*.local

# macOS
.DS_Store

# Editor/IDE
.vscode/
.idea/
*.swp
.cache/
compile_commands.json
